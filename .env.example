# ══════════════════════════════════════════════════════════════════════
#  NEXUS QUANTUM ULTRA — Environment Variables Template
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o .env no repositório!
# ══════════════════════════════════════════════════════════════════════

# ── Deriv New API 2026 ────────────────────────────────────────────────
# App ID registrado em: https://api.deriv.com/
DERIV_APP_ID=seu_app_id_aqui

# Token de API pessoal (gerado em: app.deriv.com -> API Token)
DERIV_API_TOKEN=seu_token_aqui

# Login ID da conta (encontrado em: app.deriv.com -> conta ativa)
# Demo:  VRTC123456
# Real:  CR123456
DERIV_ACCOUNT_ID=VRTCseu_loginid

# Tipo de conta: demo | real
DERIV_ACCOUNT_TYPE=demo

# ── Groq (3 chaves para round-robin de rate-limit) ────────────────────
# Gere em: https://console.groq.com/keys
GROQ_KEY_1=gsk_...
GROQ_KEY_2=gsk_...
GROQ_KEY_3=gsk_...

# Modelos Groq por agente do conclave
GROQ_MODEL_A=moonshotai/kimi-k2-instruct
GROQ_MODEL_B=meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_MODEL_C=llama-3.3-70b-versatile

# ── Telegram (opcional — notificações de trade) ───────────────────────
# 1. Crie um bot em: https://t.me/BotFather -> /newbot
# 2. Copie o token gerado
TELEGRAM_BOT_TOKEN=
# 3. Envie uma mensagem ao bot e acesse:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    para encontrar o chat_id
TELEGRAM_CHAT_ID=

# ── Trading ───────────────────────────────────────────────────────────
MIN_STAKE=0.35
MAX_STAKE=50.0
STOP_LOSS=20.0
TAKE_PROFIT=50.0
MARTINGALE_MULT=2.1
MARTINGALE_SAFE=1.5
MAX_MARTINGALE_LVL=4
MIN_CONFIDENCE=0.62
ANALYSIS_INTERVAL=30

# ── Neural Network ────────────────────────────────────────────────────
NN_RETRAIN_EVERY=50
NN_LOOKBACK=50
NN_HIDDEN_SIZE=128
