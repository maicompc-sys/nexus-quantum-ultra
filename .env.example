# ══════════════════════════════════════════════
#  NEXUS QUANTUM ULTRA — Environment Variables
# ══════════════════════════════════════════════

# Deriv
DERIV_APP_ID=1089
DERIV_API_TOKEN=seu_token_aqui
DERIV_ACCOUNT_TYPE=demo

# Groq (3 chaves para round-robin)
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...

# Modelos Groq (opcionais — defaults já definidos)
GROQ_MODEL_A=moonshotai/kimi-k2-instruct
GROQ_MODEL_B=meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_MODEL_C=llama-3.3-70b-versatile

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading
MIN_STAKE=0.35
MAX_STAKE=50.0
STOP_LOSS=20.0
TAKE_PROFIT=15.0
MARTINGALE_MULT=2.1
MARTINGALE_SAFE=1.6
MAX_MARTINGALE_LVL=3
MIN_CONFIDENCE=0.65
ANALYSIS_INTERVAL=60

# Neural Network
NN_RETRAIN_EVERY=100
NN_LOOKBACK=60
